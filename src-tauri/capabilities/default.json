{
  "identifier": "default",
  "description": "Default capabilities for Fortuna",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "shell:allow-spawn",
    "shell:allow-execute",
    "opener:default",
    {
      "identifier": "shell:allow-spawn",
      "allow": [
        {
          "name": "fortuna-server",
          "cmd": "binaries/fortuna-server",
          "args": true
        }
      ]
    }
  ]
}
